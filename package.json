{
  "name": "@openfeature/mcp",
  "version": "0.0.22",
  "mcpName": "dev.openfeature/mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/open-feature/mcp"
  },
  "type": "module",
  "scripts": {
    "build": "npm run build-providers && npm run build-prompts && tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "node dist/cli.js",
    "build-prompts": "node scripts/build-prompts.js",
    "build-providers": "node scripts/build-providers.js",
    "prepack": "npm run build",
    "test": "vitest run"
  },
  "bin": {
    "openfeature-mcp": "dist/cli.js"
  },
  "engines": {
    "node": ">=18.17"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  },
  "packageManager": "npm@>=11.5.1"
}
